{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3000",
    "build": "next build",
    "start": "next start -p 3000",
    "lint": "eslint",
    "codegen": "graphql-codegen --config codegen.yml",
    "codegen:watch": "graphql-codegen --config codegen.yml --watch",
    "grpc:generate": "bash scripts/generate-grpc-types.sh",
    "grpc:watch": "nodemon --watch proto --ext proto --exec 'npm run grpc:generate'",
    "types:generate": "npm run codegen && npm run grpc:generate",
    "types:watch": "concurrently \"npm run codegen:watch\" \"npm run grpc:watch\""
  },
